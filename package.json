{
  "name": "code-generator",
  "displayName": "code-generator",
  "publisher": "mrfrolk",
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/devabacus/code-generator.git"
  },
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-generator.flutter-handler",
        "title": "Flutter handler"
      },
      {
        "command": "code-generator.vsCodeExtHandler",
        "title": "AntigravityHandler"
      },
      {
        "command": "code-generator.createNewProject",
        "title": "Code Generator: Create New Serverpod Project"
      },
      {
        "command": "code-generator.addPython",
        "title": "Code Generator: Add Python to Serverpod Project"
      },
      {
        "command": "code-generator.addGo",
        "title": "Code Generator: Add Go to Serverpod Project"
      },
      {
        "command": "code-generator.addNode",
        "title": "Code Generator: Add Node.js to Serverpod Project"
      },
      {
        "command": "code-generator.createDataFiles",
        "title": "Code Generator: Create Data Files from YAML"
      },
      {
        "command": "code-generator.generateK8s",
        "title": "Code Generator: Generate Serverpod K8s Files"
      },
      {
        "command": "code-generator.addPythonProject",
        "title": "Code Generator: Add Python Project from Template"
      },
      {
        "command": "code-generator.addNodeProject",
        "title": "Code Generator: Add Node.js Project from Template"
      },
      {
        "command": "code-generator.addGoProject",
        "title": "Code Generator: Add Go Project from Template"
      },
      {
        "command": "code-generator.importMicroservice",
        "title": "Code Generator: Import Existing Microservice to Monorepo"
      },
      {
        "command": "code-generator.exportMicroservice",
        "title": "Code Generator: Export Microservice from Monorepo"
      },
      {
        "command": "code-generator.setupCICD",
        "title": "Code Generator: Setup CI/CD (Terraform)"
      },
      {
        "command": "code-generator.removeMicroservice",
        "title": "Code Generator: Remove Microservice from Project"
      }
    ],
    "configuration": {
      "title": "Code Generator",
      "properties": {
        "codeGenerator.templatesPath": {
          "type": "string",
          "default": "G:/Templates",
          "description": "Path to templates folder (e.g., G:/Templates with subfolders python/, node/, go/)"
        },
        "codeGenerator.pythonProjectsPath": {
          "type": "string",
          "default": "G:/Projects/Python",
          "description": "Default path for standalone Python projects"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/vscode": "^1.104.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.48.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}